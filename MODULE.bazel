"""dsa_study_packet: Bazel module exposing the company-neutral DSA study booklet.

The booklet TeX is generated from source by the uv/just pipeline
(`just packet` -> gen_booklet.py -> booklet.tex). Bazel compiles that TeX to a
PDF via rules_tectonic, so private downstream modules can \\includepdf the
neutral packet and wrap it with company-specific front/back matter.

Public targets:
  - //:booklet       Compiled neutral study packet PDF
  - booklet.tex      Generated SSOT TeX source (exported)
"""

module(
    name = "dsa_study_packet",
    version = "0.1.0",
    compatibility_level = 1,
)

bazel_dep(name = "rules_shell", version = "0.6.1")
bazel_dep(name = "rules_tectonic", version = "0.1.0")

# Until rules_tectonic is published to a registry, point at the upstream repo
# directly.
git_override(
    module_name = "rules_tectonic",
    remote = "https://github.com/jesssullivan/rules_tectonic.git",
    branch = "main",
)
