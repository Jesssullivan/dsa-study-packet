# OS
.DS_Store
Thumbs.db

# IDE — track the template's committed VS Code config, ignore everything else
# (!.vscode/ first: re-includes the dir itself so per-file negations work even
# under a machine-global '.vscode/' ignore rule)
.idea/
!.vscode/
.vscode/*
!.vscode/tasks.json
!.vscode/settings.json
!.vscode/extensions.json

# Tracked on purpose: the @AGENTS.md pointer stub for Claude Code
# (overrides any local excludes that ignore ad-hoc CLAUDE.md files)
!CLAUDE.md
*.swp
*.swo
*~

# MkDocs
site/
docs/SUMMARY.md
docs/algorithms/

# PDF booklet build artifacts
booklet.tex
booklet.pdf
docs/assets/booklet.pdf
reference-sheets/pdf/

# Secrets
.env
.env.*
!.env.example
*.sops.yaml
*.sops.json
.sops.yaml

# Challenge mode (incl. personal rep scores — publish aggregates deliberately, never raw)
.challenges/

# Agent-workflow scratch worktrees
.claude/worktrees/

# Bazel
/bazel-*
user.bazelrc
MODULE.bazel.lock
.gstack/

# Generated visualizer traces
docs/assets/traces/
