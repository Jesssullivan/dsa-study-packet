# Bazel config for dsa_study_packet.
#
# Local-default flags ONLY. All remote cache / RBE behavior lives in the
# kit-owned, endpoint-free .bazelrc.flywheel (build:ci-cached + build:executor-backed),
# imported below. Endpoints/auth are NEVER committed here -- the
# gloriousflywheel-bazel wrapper injects --remote_cache=$BAZEL_REMOTE_CACHE at
# invocation, after a strict preflight. Drive every build through `just remote-*`
# (or the kit's `just flywheel-*`), never raw bazel. Remote EXECUTION stays
# opt-in and is NOT enabled for this repo (no proved REAPI target class).

common --enable_bzlmod
build --incompatible_strict_action_env
build --disk_cache=~/.cache/bazel/dsa-study-packet
test --test_output=errors

# GloriousFlywheel front-door kit fragment: endpoint-free build:ci-cached +
# build:executor-backed. The wrapper selects --config=ci-cached in
# shared-cache-backed mode and adds the concrete endpoint flag at invocation.
try-import %workspace%/.bazelrc.flywheel

# User-local overrides last so developers can still override the kit.
try-import %workspace%/user.bazelrc
