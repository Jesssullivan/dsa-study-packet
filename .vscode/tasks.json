{
  "version": "2.0.0",
  "tasks": [
    {
      "label": "practice: start editor rep",
      "type": "shell",
      "command": "just practice-start ${input:practiceParadigm}",
      "presentation": {
        "group": "practice",
        "panel": "shared",
        "reveal": "always",
        "focus": true
      },
      "problemMatcher": []
    },
    {
      "label": "practice: show next action",
      "type": "shell",
      "command": "just practice-next",
      "presentation": {
        "group": "practice",
        "panel": "shared",
        "reveal": "always"
      },
      "problemMatcher": []
    },
    {
      "label": "practice: test current rep",
      "type": "shell",
      "command": "just practice-test",
      "presentation": {
        "group": "practice",
        "panel": "shared",
        "reveal": "always"
      },
      "problemMatcher": []
    },
    {
      "label": "practice: watch current rep",
      "type": "shell",
      "command": "just practice-watch",
      "isBackground": true,
      "presentation": {
        "group": "practice",
        "panel": "shared",
        "reveal": "always"
      },
      "problemMatcher": []
    },
    {
      "label": "practice: open current rep",
      "type": "shell",
      "command": "just practice-open",
      "presentation": {
        "group": "practice",
        "panel": "shared",
        "reveal": "silent"
      },
      "problemMatcher": []
    },
    {
      "label": "practice: REPL for current rep",
      "type": "shell",
      "command": "just practice-repl",
      "presentation": {
        "group": "practice",
        "panel": "shared",
        "reveal": "always",
        "focus": true
      },
      "problemMatcher": []
    },
    {
      "label": "practice: finish current rep",
      "type": "process",
      "command": "just",
      "args": ["practice-finish", "${input:practiceFinishNote}"],
      "presentation": {
        "group": "practice",
        "panel": "shared",
        "reveal": "always"
      },
      "problemMatcher": []
    },
    {
      "label": "DSA: test",
      "type": "shell",
      "command": "just test",
      "group": "test",
      "problemMatcher": []
    },
    {
      "label": "DSA: lint",
      "type": "shell",
      "command": "just lint",
      "group": "test",
      "problemMatcher": []
    },
    {
      "label": "DSA: packet",
      "type": "shell",
      "command": "just packet",
      "group": "build",
      "problemMatcher": []
    },
    {
      "label": "DSA: docs",
      "type": "shell",
      "command": "just docs",
      "group": "build",
      "isBackground": true,
      "problemMatcher": []
    }
  ],
  "inputs": [
    {
      "id": "practiceParadigm",
      "type": "pickString",
      "description": "Reasoning framework",
      "default": "reacto",
      "options": ["reacto", "clarp", "umpire", "comments"]
    },
    {
      "id": "practiceFinishNote",
      "type": "promptString",
      "description": "One specific fix for the next rep"
    }
  ]
}
