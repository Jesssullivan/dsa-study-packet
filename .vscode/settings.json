{
  "python.defaultInterpreterPath": "${workspaceFolder}/.venv/bin/python",
  "python.analysis.extraPaths": ["${workspaceFolder}/src"],
  "python.testing.pytestEnabled": false,
  "python.testing.unittestEnabled": false,
  "ruff.nativeServer": "on",
  "ruff.organizeImports": true,
  "chat.useAgentsMdFile": true,
  "github.copilot.chat.codeGeneration.useInstructionFiles": false,
  "chat.promptFilesRecommendations": {
    "reacto": true,
    "clarp": true,
    "umpire": true,
    "comments": true,
    "continue": true
  },
  "chat.tools.terminal.autoApprove": {
    "/^just practice-start\\b.*$/": true,
    "/^just practice-next$/": true,
    "/^just practice-test$/": true,
    "/^just practice-watch$/": true,
    "/^just practice-repl$/": true,
    "/^just practice-open\\b.*$/": true,
    "/^just practice-finish\\b.*$/": true,
    "/^just practice-reference\\b.*$/": true,
    "/^just interview\\b.*$/": true,
    "/^just catalog\\b.*$/": true,
    "/^uv run pytest\\b.*$/": true
  },
  "github.copilot.enable": {
    "*": false
  },
  "github.copilot.nextEditSuggestions.enabled": false,
  "editor.formatOnSave": true,
  "[python]": {
    "editor.defaultFormatter": "charliermarsh.ruff"
  },
  "files.exclude": {
    "**/__pycache__": true,
    ".mypy_cache": true,
    ".pytest_cache": true,
    ".ruff_cache": true,
    ".hypothesis": true,
    "site": true,
    "bazel-*": true
  }
}
