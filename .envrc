# Local dev shell + optional remote Bazel cache attach. The cache is an env
# contract: your machine profile (or the gitignored .env.flywheel.local)
# supplies BAZEL_REMOTE_CACHE + auth and puts the cache-aware bazel wrapper +
# bazelisk on PATH. Never commit endpoints.
if has nix; then
  use flake . --impure
fi

# Optional local cache profile (gitignored, non-secret: endpoint + mode only).
# Do NOT source the unrelated repo .env.
[ -f .env.flywheel.local ] && dotenv .env.flywheel.local

# Derive the substrate mode from cache presence (mirrors examples/flake/.envrc).
if [ -n "${BAZEL_REMOTE_CACHE:-}" ]; then
  export GF_BAZEL_SUBSTRATE_MODE=shared-cache-backed
else
  export GF_BAZEL_SUBSTRATE_MODE=compatibility-local-only
fi
