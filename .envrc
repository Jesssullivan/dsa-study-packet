# Local dev attach to GloriousFlywheel. Bazel cache attachment is an env
# contract: the fleet Nix/Home-Manager profile (or .env.flywheel.local) supplies
# BAZEL_REMOTE_CACHE + auth and puts gloriousflywheel-bazel + bazelisk on PATH.
# Never commit endpoints.
if has nix; then
  use flake . --impure
fi

# Source the bounded GloriousFlywheel fallback profile if present (gitignored,
# non-secret: endpoint + mode only). Do NOT source the unrelated repo .env.
[ -f .env.flywheel.local ] && dotenv .env.flywheel.local

# Derive the substrate mode from cache presence (mirrors examples/flake/.envrc).
if [ -n "${BAZEL_REMOTE_CACHE:-}" ]; then
  export GF_BAZEL_SUBSTRATE_MODE=shared-cache-backed
else
  export GF_BAZEL_SUBSTRATE_MODE=compatibility-local-only
fi
